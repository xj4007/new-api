# Docker Compose substitution values
NEW_API_CONTAINER_NAME=new-api-app
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=3000

# Required runtime values
SQL_DSN=postgresql://newapi:change_me_db_password@new-api-postgres:5432/new_api
REDIS_CONN_STRING=redis://:change_me_redis_password@new-api-redis:6379/0
SESSION_SECRET=change_me_session_secret
CRYPTO_SECRET=change_me_crypto_secret
NODE_TYPE=master
NODE_NAME=new-api-app-1
TZ=Asia/Shanghai

# Recommended explicit values for current production behavior
ERROR_LOG_ENABLED=true
MEMORY_CACHE_ENABLED=true
BATCH_UPDATE_ENABLED=true
CHANNEL_UPDATE_FREQUENCY=30
STREAMING_TIMEOUT=300
RELAY_TIMEOUT=0

# Usually leave unset unless you have a confirmed need
# SQL_MAX_IDLE_CONNS=100
# SQL_MAX_OPEN_CONNS=1000
# SQL_MAX_LIFETIME=60
# SYNC_FREQUENCY=60
# BATCH_UPDATE_INTERVAL=5
# RELAY_IDLE_CONN_TIMEOUT=90

# Do not enable for the current single master topology unless you intentionally
# deploy a redirect-only node. On master nodes this value is ignored by code.
# FRONTEND_BASE_URL=https://your-frontend.example.com
